<?php

/**
 * @file
 * Tugboat Drupal settings.
 *
 * This file cannot be edited, but you can add/override Tugboat settings after
 * it has been included in the main settings.php file.
 */

declare(strict_types=1);

if (getenv('TUGBOAT_REPO')) {
  $databases['default']['default'] = [
    'database' => 'tugboat',
    'username' => 'tugboat',
    'password' => 'tugboat',
    'prefix' => '',
    'host' => '{{ services.database.type }}',
    'port' => '3306',
    'namespace' => 'Drupal\\Core\\Database\\Driver\\mysql',
    'driver' => 'mysql',
  ];

  $settings['hash_salt'] = hash('sha256', getenv('TUGBOAT_REPO_ID'));

  $settings['trusted_host_patterns'] = [
    '\.tugboatqa\.com$',
  ];

  // See https://architecture.lullabot.com/adr/20210609-environment-indicator/
  $config['environment_indicator.indicator']['name'] = 'Tugboat: ' . getenv('TUGBOAT_PREVIEW');
  $config['environment_indicator.indicator']['bg_color'] = '#20688C';
  $config['environment_indicator.indicator']['fg_color'] = '#ffffff';

  // Keep the sites/default directory writable.
  $settings['skip_permissions_hardening'] = TRUE;

  // Enable mail to be captured by Tugboat.
  $config['system.mail']['interface']['default'] = 'php_mail';
  // Mail System
  $config['mailsystem.settings']['defaults']['sender'] = 'php_mail';
  // Symfony Mailer 1.x
  $config['symfony_mailer.settings']['default_transport'] = 'sendmail';
  $config['symfony_mailer.mailer_transport.sendmail']['plugin'] = 'smtp';
  $config['symfony_mailer.mailer_transport.sendmail']['configuration']['user'] = '';
  $config['symfony_mailer.mailer_transport.sendmail']['configuration']['pass'] = '';
  $config['symfony_mailer.mailer_transport.sendmail']['configuration']['host'] = getenv('TUGBOAT_SMTP');
  $config['symfony_mailer.mailer_transport.sendmail']['configuration']['port'] = '25';
  // Symfony Mailer 2.x
  $config['mailer_transport.settings']['default_transport'] = 'sendmail';
  $config['mailer_transport.mailer_transport.sendmail']['plugin'] = 'smtp';
  $config['mailer_transport.mailer_transport.sendmail']['configuration']['user'] = '';
  $config['mailer_transport.mailer_transport.sendmail']['configuration']['pass'] = '';
  $config['mailer_transport.mailer_transport.sendmail']['configuration']['host'] = getenv('TUGBOAT_SMTP');
  $config['mailer_transport.mailer_transport.sendmail']['configuration']['port'] = '1025';
}
