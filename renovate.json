{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "rangeStrategy": "widen",
  "ignoreDeps": [
    "drainpipe"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "drush/drush",
        "phpunit/phpunit",
        "symfony/phpunit-bridge",
        "symfony/yaml",
        "twig/twig",
        "vlucas/phpdotenv"
      ],
      "addLabels": [
        "test only - do not merge"
      ]
    },
    {
      "matchPackageNames": [
        "lullabot/drainpipe",
        "lullabot/drainpipe-dev"
      ],
      "enabled": false
    },
    {
      "matchPackageNames": [
        "drush/drush"
      ],
      "allowedVersions": "^11 || ^12 || ^13"
    },
    {
      "matchPackageNames": [
        "phpunit/phpunit"
      ],
      "allowedVersions": "^9"
    },
    {
      "matchPackageNames": [
        "phpunit/phpunit"
      ],
      "matchFileNames": [
        "drainpipe-dev/composer.json"
      ],
      "allowedVersions": "^9 || ^10 || ^11"
    },
    {
      "matchPackageNames": [
        "mglaman/phpstan-drupal",
        "phpstan/phpstan-deprecation-rules"
      ],
      "allowedVersions": "^1 || ^2"
    },
    {
      "matchPackageNames": [
        "vlucas/phpdotenv"
      ],
      "allowedVersions": "^4 || ^5"
    },
    {
      "matchPackageNames": [
        "/^symfony\//"
      ],
      "allowedVersions": "^6 || ^7"
    },
    {
      "matchDatasources": ["node-version"],
      "matchUpdateTypes": ["major"],
      "rangeStrategy": "replace"
    },
    {
      "matchDatasources": ["node-version"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "enabled": false
    },
    {
      "matchPackageNames": ["go-task/task"],
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+$/",
      "rangeStrategy": "replace",
      "groupName": "Taskfile"
    },
    {
      "matchPackageNames": ["mikefarah/yq"],
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+$/",
      "rangeStrategy": "replace"
    },
    {
      "matchPackageNames": ["zizmor"],
      "rangeStrategy": "replace"
    },
    {
      "matchPackageNames": ["yarn"],
      "matchFileNames": [
        ".github/workflows/TestMetapackages.yml",
        ".github/workflows/TestFunctional.yml"
      ],
      "allowedVersions": "^1",
      "rangeStrategy": "replace"
    },
    {
      "matchPackageNames": ["yarn"],
      "matchFileNames": [
        "package.json"
      ],
      "allowedVersions": "^4",
      "rangeStrategy": "replace"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "^\\.taskfile$",
        "scaffold/tugboat/scripts/custom-init-command\\.sh$"
      ],
      "matchStrings": [
        "(?:TASKFILE=|^)v(?<currentValue>\\d+\\.\\d+\\.\\d+)\\s*$"
      ],
      "depNameTemplate": "go-task/task",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "scaffold/tugboat/scripts/custom-init-command\\.sh$"
      ],
      "matchStrings": [
        "YQ=v(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "mikefarah/yq",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "\\.github/workflows/Security\\.yml$"
      ],
      "matchStrings": [
        "zizmor==(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "zizmor",
      "datasourceTemplate": "pypi"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "\\.github/workflows/TestMetapackages\\.yml$",
        "\\.github/workflows/TestFunctional\\.yml$"
      ],
      "matchStrings": [
        "yarn@(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "yarn",
      "datasourceTemplate": "npm"
    }
  ]
}
